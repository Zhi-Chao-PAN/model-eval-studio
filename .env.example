# ========== 数据库 ==========
# PostgreSQL 连接地址（Neon 等云数据库的 pooled 连接）
# 用于应用运行时的数据库查询
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require&pgbouncer=true

# PostgreSQL 直连地址（非 pooled，用于 Prisma 迁移）
# Neon 等服务需要单独配置 DIRECT_URL 运行 migration
DIRECT_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ========== 会话 & 加密 ==========
# iron-session 会话加密密钥，至少 32 个字符
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=请替换为至少32位的随机字符串

# 用户 AI API Key 的 AES-256-GCM 加密密钥
# 推荐：64 位十六进制字符串（32 字节满熵），生成方式：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 也支持任意 >=32 字符的普通字符串（向后兼容），但推荐 hex 格式。
ENCRYPTION_KEY=请替换为64位十六进制的随机密钥

# ========== 文件存储（可选） ==========
# Vercel Blob 读写令牌。未配置时使用本地文件存储（.local-artifacts/）
# Vercel 平台部署时由 Vercel Blob 集成自动注入，通常无需手动设置
BLOB_READ_WRITE_TOKEN=
# Vercel 平台自动注入（部署时无需手动设置）
# BLOB_STORE_ID=
# VERCEL=1
# VERCEL_ENV=production

# ========== 构建/迁移 ==========
# 生产构建（next build）时默认自动执行 prisma migrate deploy。
# 本地/CI 需要强制跑迁移时可设置 FORCE_MIGRATE=1。
# FORCE_MIGRATE=1

# ========== 初始管理员 ==========
# 首次执行 pnpm init:admin 时创建的管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置管理员密码
