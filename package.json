    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "officeparser": "^7.2.1",
    "openai": "^6.43.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
