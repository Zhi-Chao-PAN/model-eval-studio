// Prisma schema for model-test-assistant
// PostgreSQL 版本（Vercel + Neon 部署用）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum TaskStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  DELETED
}

enum TaskStep {
  DESIGN
  INFO
  IDEA
  SCREENSHOT
  ARTIFACT
  REPORT
}

enum AiProvider {
  OPENAI_COMPAT
  ANTHROPIC_COMPAT
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  TASK_CREATE
  TASK_UPDATE
  TASK_DELETE
  MODEL_ADD
  MODEL_DELETE
  MODEL_UPDATE
  ARTIFACT_UPLOAD
  ARTIFACT_DELETE
  AI_CHAT
  AI_IDEA_GENERATE
  AI_SCREENSHOT_ANALYZE
  AI_ARTIFACT_ANALYZE
  AI_REPORT_GENERATE
  USER_SETTINGS_UPDATE
  AI_CONFIG_UPDATE
  ADMIN_INVITE_CREATE
  ADMIN_INVITE_TOGGLE
  ADMIN_USER_VIEW
  ADMIN_AUDIT_VIEW
  EXPORT
  COLLABORATOR_ADD
  COLLABORATOR_REMOVE
  COLLABORATOR_UPDATE
  SHARE_CREATE
  SHARE_REVOKE
  PASSWORD_CHANGE
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  background    String?
  aiProvider    AiProvider @default(OPENAI_COMPAT)
  aiBaseUrl     String?
  aiApiKey      String?
  aiModelName   String?
  aiMaxTokens   Int?      @map("ai_max_tokens")
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  tasks         Task[]
  inviteCodes   InviteCode[] @relation("CreatedInvites")
  auditLogs     AuditLog[]
  sharedTasks   TaskCollaborator[]
  createdShares TaskShare[] @relation("TaskShareCreator")
  editedReports ModelReport[] @relation("ReportEditor")
}

model InviteCode {
  id           String   @id @default(cuid())
  code         String   @unique
  expiresAt    DateTime?
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  active       Boolean  @default(true)
  createdById  String
  createdBy    User     @relation("CreatedInvites", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@index([createdById])
  @@index([active])
}

model Task {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  category        String?
  requirementType String?
  requirementName String?
  description     String?
  backgroundUsed  String?
  status          TaskStatus @default(DRAFT)
  currentStep     TaskStep @default(DESIGN)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attachments     TaskAttachment[]
  models          TaskModel[]
  messages        TaskMessage[]
  rubric          EvaluationRubric?
  shares          TaskShare[]
  collaborators   TaskCollaborator[]
  taskIdeaJson    String?
  analysisJson    String?

  @@index([userId, updatedAt])
  @@index([status, updatedAt])
  @@index([deletedAt])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  url       String
  size      Int?
  mimeType  String?
  parsedText  String?
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskModel {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  modelCode      String
  displayName    String?
  hardMetricsJson  String?
  processText    String?
  screenshotUrls String?
  verificationScreenshotUrls String?
  artifactAnalysisJson String?
  createdAt      DateTime @default(now())
  artifacts      ModelArtifact[]
  reports        ModelReport[]
  artifactAnalysisRuns ArtifactAnalysisRun[]

  @@unique([taskId, modelCode])
  @@index([taskId])
}

model ArtifactAnalysisRun {
  id                         String   @id @default(cuid())
  taskModelId                String
  taskModel                  TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  workflowRunId              String?  @unique
  status                     String   @default("QUEUED")
  currentPhase               String?
  error                      String?  @db.Text
  artifactSignature          String?
  verificationEvidenceSignature String?
  artifactCount              Int?
  verificationScreenshotUrls String?
  verificationSummary        String?  @db.Text
  filesAnalysis              String?  @db.Text
  nextEventSeq               Int      @default(0)
  startedAt                  DateTime?
  completedAt                DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  events                     ArtifactAnalysisEvent[]

  @@index([taskModelId, createdAt])
  @@index([status, updatedAt])
}

model ArtifactAnalysisEvent {
  id        String   @id @default(cuid())
  runId     String
  run       ArtifactAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence  Int
  phase     String
  status    String
  label     String
  detail    String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([runId, sequence])
}

model ModelArtifact {
  id        String   @id @default(cuid())
  taskModelId String
  taskModel TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  name      String
  url       String
  textContent String?
  mimeType  String?
  size      Int?
  parsedText String?
  previewJson String?
  createdAt DateTime @default(now())

  @@index([taskModelId, createdAt])
}

model ModelReport {
  id                  String   @id @default(cuid())
  taskModelId         String
  taskModel           TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  version             Int      @default(1)
  source              String   @default("AI_GENERATED") // AI_GENERATED | AI_ADJUSTED | MANUAL
  parentReportId      String?  // 上一版本 ID，形成修订链
  parentReport        ModelReport? @relation("ReportRevision", fields: [parentReportId], references: [id], onDelete: SetNull)
  childReports        ModelReport[] @relation("ReportRevision")
  editedById          String?  // 人工修订者用户 ID
  editedBy            User?    @relation("ReportEditor", fields: [editedById], references: [id], onDelete: SetNull)
  editNote            String?  // 修订说明
  productFeedback     String
  verificationScreenshotUrls String?
  verificationSummary String?
  overallScore        Float
  overallComment      String
  efficiencyScore     Float
  efficiencyComment   String
  qualityScore        Float
  qualityComment      String
  trajectoryAnalysis  String?
  generationSnapshot  String?  @db.Text // 生成依据 JSON 快照
  generationConfig    String?  @db.Text // 生成时的 rubric/prompt 配置快照
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([taskModelId, createdAt])
  @@unique([taskModelId, version])
  @@index([parentReportId])
}

model TaskMessage {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role      String
  content   String
  step      TaskStep
  modelId   String?
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([modelId])
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      AuditAction
  detail      Json?
  ipAddress   String?
  userAgent   String?
  path        String?
  method      String?
  status      String?
  error       String?     @db.Text
  tokenInput  Int?
  tokenOutput Int?
  durationMs  Int?
  taskId      String?
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@index([taskId])
}

model EvaluationRubric {
  id             String   @id @default(cuid())
  taskId         String   @unique
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  templateType   String   // "CODING" | "AGENT" | "CUSTOM"
  dimensionsJson String   // JSON 数组：[{key, label, weight, description, scoreRange}]
  overallFormula String?  // 综合分计算公式描述
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RateLimitBucket {
  id          String   @id
  count       Int      @default(0)
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model TaskShare {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  token       String   @unique
  accessType  String   @default("VIEW") // VIEW 只读
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("TaskShareCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskCollaborator {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "VIEWER" | "EDITOR"
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}
