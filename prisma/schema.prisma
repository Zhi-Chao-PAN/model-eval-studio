// Prisma schema for model-test-assistant
// PostgreSQL 版本（Vercel + Neon 部署用）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum TaskStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  DELETED
}

enum TaskStep {
  DESIGN
  INFO
  IDEA
  SCREENSHOT
  ARTIFACT
  REPORT
}

enum AiProvider {
  OPENAI_COMPAT
  ANTHROPIC_COMPAT
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  TASK_CREATE
  TASK_UPDATE
  TASK_DELETE
  MODEL_ADD
  MODEL_DELETE
  MODEL_UPDATE
  ARTIFACT_UPLOAD
  ARTIFACT_DELETE
  AI_CHAT
  AI_IDEA_GENERATE
  AI_SCREENSHOT_ANALYZE
  AI_ARTIFACT_ANALYZE
  AI_REPORT_GENERATE
  USER_SETTINGS_UPDATE
  AI_CONFIG_UPDATE
  ADMIN_INVITE_CREATE
  ADMIN_INVITE_TOGGLE
  ADMIN_USER_VIEW
  ADMIN_AUDIT_VIEW
  EXPORT
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  background    String?
  aiProvider    AiProvider @default(OPENAI_COMPAT)
  aiBaseUrl     String?
  aiApiKey      String?
  aiModelName   String?
  aiMaxTokens   Int?      @map("ai_max_tokens")
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  tasks         Task[]
  inviteCodes   InviteCode[] @relation("CreatedInvites")
  auditLogs     AuditLog[]
}

model InviteCode {
  id           String   @id @default(cuid())
  code         String   @unique
  expiresAt    DateTime?
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  active       Boolean  @default(true)
  createdById  String
  createdBy    User     @relation("CreatedInvites", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
}

model Task {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  category        String?
  requirementType String?
  requirementName String?
  description     String?
  backgroundUsed  String?
  status          TaskStatus @default(DRAFT)
  currentStep     TaskStep @default(INFO)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attachments     TaskAttachment[]
  models          TaskModel[]
  messages        TaskMessage[]
  taskIdeaJson    String?
  analysisJson    String?
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  url       String
  size      Int?
  mimeType  String?
  parsedText  String?
  createdAt DateTime @default(now())
}

model TaskModel {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  modelCode      String
  displayName    String?
  hardMetricsJson  String?
  processText    String?
  screenshotUrls String?
  verificationScreenshotUrls String?
  artifactAnalysisJson String?
  createdAt      DateTime @default(now())
  artifacts      ModelArtifact[]
  reports        ModelReport[]
  artifactAnalysisRuns ArtifactAnalysisRun[]

  @@unique([taskId, modelCode])
}

model ArtifactAnalysisRun {
  id                         String   @id @default(cuid())
  taskModelId                String
  taskModel                  TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  workflowRunId              String?  @unique
  status                     String   @default("QUEUED")
  currentPhase               String?
  error                      String?  @db.Text
  artifactSignature          String?
  verificationEvidenceSignature String?
  artifactCount              Int?
  verificationScreenshotUrls String?
  verificationSummary        String?  @db.Text
  filesAnalysis              String?  @db.Text
  nextEventSeq               Int      @default(0)
  startedAt                  DateTime?
  completedAt                DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  events                     ArtifactAnalysisEvent[]

  @@index([taskModelId, createdAt])
  @@index([status, updatedAt])
}

model ArtifactAnalysisEvent {
  id        String   @id @default(cuid())
  runId     String
  run       ArtifactAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence  Int
  phase     String
  status    String
  label     String
  detail    String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([runId, sequence])
  @@unique([runId, sequence])
}

model ModelArtifact {
  id        String   @id @default(cuid())
  taskModelId String
  taskModel TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  name      String
  url       String
  textContent String?
  mimeType  String?
  size      Int?
  parsedText String?
  previewJson String?
  createdAt DateTime @default(now())
}

model ModelReport {
  id                String   @id @default(cuid())
  taskModelId       String
  taskModel         TaskModel @relation(fields: [taskModelId], references: [id], onDelete: Cascade)
  productFeedback   String
  verificationScreenshotUrls String?
  verificationSummary String?
  overallScore      Float
  overallComment    String
  efficiencyScore   Float
  efficiencyComment String
  qualityScore      Float
  qualityComment    String
  trajectoryAnalysis String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TaskMessage {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role      String
  content   String
  step      TaskStep
  modelId   String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      AuditAction
  detail      Json?
  ipAddress   String?
  userAgent   String?
  path        String?
  method      String?
  status      String?
  error       String?     @db.Text
  tokenInput  Int?
  tokenOutput Int?
  durationMs  Int?
  taskId      String?
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model RateLimitBucket {
  id          String   @id
  count       Int      @default(0)
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}
